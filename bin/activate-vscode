#!/bin/sh

WINDOW_ID=$(/usr/bin/xdotool search --name "Visual Studio Code" | head -1)
echo $WINDOW_ID
if [ -z "$WINDOW_ID" ]
then
  env BAMF_DESKTOP_FILE_HINT=/var/lib/snapd/desktop/applications/code_code.desktop /snap/bin/code --force-user-env --no-sandbox --unity-launch
else
  /usr/bin/xdotool windowactivate $WINDOW_ID
fi

